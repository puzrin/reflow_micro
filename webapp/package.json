{
  "name": "reflow_mock",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write src/",
    "gen:proto:ts": "protoc --ts_proto_out=./src/proto/generated --ts_proto_opt=esModuleInterop=true,snakeToCamel=false,outputJsonMethods=false --proto_path=./src/proto types.proto",
    "gen:proto:cpp": "nanopb_generator --proto-path=./src/proto types.proto --output-dir ../firmware/src/proto/generated",
    "gen:proto:data": "tsx ./src/proto/gen_defaults.ts",
    "gen:proto": "run-s gen:proto:ts gen:proto:cpp gen:proto:data",
    "test": "run-p lint type-check && vitest run"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@msgpack/msgpack": "^3.1.3",
    "@pinia/colada": "^1.0.0",
    "@vueuse/core": "^14.2.1",
    "d3": "^7.9.0",
    "filenamify": "^7.0.1",
    "ky": "^1.14.3",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.30",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^5.0.3",
    "vuetify": "^4.0.2"
  },
  "devDependencies": {
    "@iconify-json/material-symbols": "^1.2.62",
    "@tsconfig/node20": "^20.1.9",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.5.0",
    "@types/web-bluetooth": "^0.0.21",
    "@unocss/preset-icons": "^66.4.2",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "git-remote-origin-url": "^4.0.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "protoc": "^34.0.0",
    "ts-proto": "^2.11.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unocss": "^66.6.6",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  }
}
